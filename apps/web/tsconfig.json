{
	"extends": "@repo/typescript-config/react-router.json",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@/*": ["./*"],
			"~/*": ["./app/*"]
		},
		"types": ["node", "vite/client"],
		"verbatimModuleSyntax": true,
		"rootDirs": [".", "./.react-router/types"]
	},
	"include": ["**/*", "**/.server/**/*", "**/.client/**/*", ".react-router/types/**/*"],
	"exclude": ["node_modules", "build"]
}
