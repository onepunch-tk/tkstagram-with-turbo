{
	"compilerOptions": {
		// 컴파일된 JS의 ECMAScript 버전 (ES2020 문법으로 출력)
		"target": "ES2020",
		// 모듈 시스템 (commonjs = require/module.exports 방식으로 출력)
		"module": "commonjs",
		// 사용 가능한 표준 라이브러리 타입 (ES2020 내장 API 타입 포함)
		"lib": ["ES2020"],
		// 모듈 경로 해석 방식 (node = Node.js의 require 해석 알고리즘 사용)
		"moduleResolution": "node",
		// 엄격한 타입 검사 활성화 (strictNullChecks, noImplicitAny 등 전부 포함)
		"strict": true,
		// CommonJS 모듈을 ES 모듈처럼 import 가능하게 함 (import x from 'cjs-module')
		"esModuleInterop": true,
		// node_modules 내 .d.ts 파일의 타입 검사를 건너뜀 (빌드 속도 향상)
		"skipLibCheck": true,
		// import 경로의 대소문자를 파일 시스템과 일치하도록 강제 (OS 간 호환성)
		"forceConsistentCasingInFileNames": true,
		// 컴파일 시 .d.ts 타입 선언 파일 생성 (외부 패키지가 타입을 참조할 수 있게)
		"declaration": true,
		// .d.ts.map 파일 생성 (IDE에서 타입 정의 → 원본 .ts 소스로 이동 가능)
		"declarationMap": true,
		// 컴파일 결과물 출력 디렉토리
		"outDir": "./dist",
		/**
		 * nestjs-trpc(v2.9.1+)가 자동 생성하는 server.ts에서 `@repo/trpc/schemas` 형태로
		 * 자기 자신 패키지를 import하는 셀프 참조 문제가 발생함.
		 * tsc는 컴파일 중인 패키지의 package.json exports를 resolve할 수 없으므로,
		 * path alias로 `@repo/trpc/*` → `./src/*`로 리다이렉트하여
		 * 외부 패키지 참조가 아닌 로컬 소스 파일 참조로 변환.
		 *
		 * NOTE: paths alias는 컴파일 패키지에서만 사용 가능.
		 * JIT(just-in-time) 패키지는 자체 tsconfig가 아닌 소비 앱(NestJS 등)의
		 * tsc가 코드를 컴파일하므로, 이 패키지의 tsconfig paths가 적용되지 않음.
		 * 컴파일 패키지는 자체 tsc로 빌드하기 때문에 자신의 tsconfig paths가 반영됨.
		 */
		"paths": {
			"@repo/trpc/*": ["./src/*"]
		}
	},
	// 컴파일 대상 파일
	"include": ["src/**/*"],
	// 컴파일에서 제외할 디렉토리
	"exclude": ["node_modules", "dist"]
}
